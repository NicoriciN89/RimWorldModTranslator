.venv/
__pycache__/
*.pyc
build/
dist/
output/
.translation_cache.json
translator.log

# Встроенный языковой пакет Argos (en->ru, ~200 МБ) для сборки .exe без
# скачивания при первом запуске — не хранится в git (слишком тяжёлый для
# истории репозитория), нужен только локально перед PyInstaller-сборкой.
# Взять из установленного Argos: скопировать папку translate-en_ru-* из
# %LOCALAPPDATA%\argos-translate\packages (Windows) или
# ~/.local/share/argos-translate/packages (Linux/Mac) сюда же.
# Исключение: модель сегментации MiniSBD (~188 КБ) хранится в git — без неё
# собранный exe скачивал бы её из интернета при первом запуске.
bundled_packages/*
!bundled_packages/minisbd/
